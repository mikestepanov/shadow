#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"
case "$session" in
  nixelo) workdir="$HOME/Desktop/nixelo" ;;
  starthub) workdir="$HOME/Desktop/StartHub" ;;
  *) echo "invalid session: $session" >&2; exit 2 ;;
esac

hour=$(TZ=America/Chicago date +%H)
roles=(auditor refactor)
idx=$((10#$hour % ${#roles[@]}))
role="${roles[$idx]}"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/terminal_mode_guard.sh"

if ! terminal_send_preflight "$session" "$workdir"; then
  case "$TERMINAL_PREFLIGHT_REASON" in
    session-missing|pane-missing)
      echo "SKIP role=${role} session=${session} reason=${TERMINAL_PREFLIGHT_REASON}"
      ;;
    path-mismatch)
      echo "SKIP role=${role} session=${session} reason=path-mismatch current=$TERMINAL_PREFLIGHT_CURRENT_PATH expected=$workdir"
      ;;
    terminal-not-ready)
      if [[ "$TERMINAL_PREFLIGHT_STATE" == BUSY:* ]]; then
        echo "NOOP:terminal-busy role=${role} session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      elif [[ "$TERMINAL_PREFLIGHT_STATE" == STUCK:* ]]; then
        echo "NOOP:terminal-stuck role=${role} session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      else
        echo "BLOCKED_HUMAN: prompt-not-ready-for-agent-ping role=${role} session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      fi
      ;;
  esac
  exit 0
fi

target="$TERMINAL_PREFLIGHT_PANE"

msg="$(cat <<EOF2
MANDATORY ORDER (same branch only):
1) Stay on your CURRENT branch. Do NOT create or switch branches.
2) Work strictly within the ${role} facet defined in .agents/${role}.txt.
3) Continue any in-progress work only if it clearly belongs to this ${role} facet.
4) Go deep on this ${role} workstream. If a broader overhaul is needed to solve the ${role} problem correctly, do it. You may make multiple related fixes in this run as long as they all belong to the same ${role} facet.
5) Keep the relevant TODOs and notes accurate as the work evolves.
6) Run the relevant checks and commit at a clean, coherent checkpoint with a focused message.
Hard rules: no destructive git commands; no new branches; no unrelated work; no background branch fan-out.
EOF2
)"

send_tmux_text_enter "$target" "$msg" || {
  echo "BLOCKED_HUMAN: prompt-not-ready-for-agent-ping role=${role} session=${session}"
  exit 0
}

echo "SENT role=${role} session=${session}"
