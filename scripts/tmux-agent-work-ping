#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"
case "$session" in
  nixelo) workdir="$HOME/Desktop/nixelo" ;;
  starthub) workdir="$HOME/Desktop/StartHub" ;;
  *) echo "invalid session: $session" >&2; exit 2 ;;
esac

hour=$(TZ=America/Chicago date +%H)
roles=(bolt sentinel spectra auditor palette inspector refactor schema scribe librarian)
idx=$((10#$hour % ${#roles[@]}))
role="${roles[$idx]}"

if ! tmux has-session -t "$session" 2>/dev/null; then
  echo "SKIP role=${role} session=${session} reason=session-missing"
  exit 0
fi

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' | head -n1)"
target="$pane"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/terminal_classifier.sh"
source "$SCRIPT_DIR/terminal_mode_guard.sh"

state="$(classify_terminal "$session")"
if [[ "$state" == BUSY:* ]]; then
  echo "NOOP:terminal-busy role=${role} session=${session} state=$state"
  exit 0
fi
if [[ "$state" == STUCK:* ]]; then
  echo "NOOP:terminal-stuck role=${role} session=${session} state=$state"
  exit 0
fi

path_now="$(tmux display-message -p -t "$pane" '#{pane_current_path}')"
if [[ "$path_now" != "$workdir" ]]; then
  echo "SKIP role=${role} session=${session} reason=path-mismatch current=$path_now expected=$workdir"
  exit 0
fi

msg="$(cat <<EOF2
MANDATORY ORDER (same branch only):
1) Finalize the current in-progress unit on your CURRENT branch and run checks that are available.
2) Do NOT create/switch branches. Stay on this exact branch.
3) Then run exactly ONE focused ${role} task from .agents/${role}.txt on this same branch.
4) After that one task, run checks and commit once with a focused message, then stop.
5) If blocked, update the relevant TODO with blocker + next step and commit that TODO update, then stop.
Hard rules: no destructive git commands; no new branches; no background branch fan-out.
EOF2
)"

send_tmux_text_enter "$target" "$msg" || {
  echo "BLOCKED_HUMAN: prompt-not-ready-for-agent-ping role=${role} session=${session}"
  exit 0
}

echo "SENT role=${role} session=${session}"