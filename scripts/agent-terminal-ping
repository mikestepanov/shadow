#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
OPENCODECTL="$SCRIPT_DIR/opencodectl"
source "$SCRIPT_DIR/terminal_mode_guard.sh"

if ! workdir="$($OPENCODECTL lane-field agent "$session" workdir 2>/dev/null)"; then
  echo "invalid session: $session" >&2
  exit 2
fi

if ! role="$($OPENCODECTL lane-field agent "$session" role 2>/dev/null)"; then
  echo "missing agent role for session: $session" >&2
  exit 2
fi

if ! msg="$($OPENCODECTL lane-field agent "$session" prompt 2>/dev/null)"; then
  echo "missing agent prompt for session: $session" >&2
  exit 2
fi

if ! terminal_send_preflight "$session" "$workdir"; then
  case "$TERMINAL_PREFLIGHT_REASON" in
    session-missing|pane-missing)
      echo "SKIP role=${role} session=${session} reason=${TERMINAL_PREFLIGHT_REASON}"
      ;;
    path-mismatch)
      echo "SKIP role=${role} session=${session} reason=path-mismatch current=$TERMINAL_PREFLIGHT_CURRENT_PATH expected=$workdir"
      ;;
    terminal-not-ready)
      if [[ "$TERMINAL_PREFLIGHT_STATE" == BUSY:* ]]; then
        echo "NOOP:terminal-busy role=${role} session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      elif [[ "$TERMINAL_PREFLIGHT_STATE" == STUCK:* ]]; then
        echo "NOOP:terminal-stuck role=${role} session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      else
        echo "BLOCKED_HUMAN: prompt-not-ready-for-agent-ping role=${role} session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      fi
      ;;
  esac
  exit 0
fi

target="$TERMINAL_PREFLIGHT_PANE"

send_tmux_text_enter "$target" "$msg" || {
  echo "BLOCKED_HUMAN: prompt-not-ready-for-agent-ping role=${role} session=${session}"
  exit 0
}

echo "SENT role=${role} session=${session}"
