#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"
case "$session" in
  nixelo)
    workdir="$HOME/Desktop/nixelo"
    dispatch_script="$SCRIPT_DIR/scripts/pr_ci_nixelo_dispatch.sh"
    ;;
  starthub)
    workdir="$HOME/Desktop/StartHub"
    dispatch_script="$SCRIPT_DIR/scripts/pr_ci_starthub_dispatch.sh"
    ;;
  *)
    echo "invalid session: $session" >&2
    exit 2
    ;;
esac

if ! tmux has-session -t "$session" 2>/dev/null; then
  echo "SKIP prci session=${session} reason=session-missing"
  exit 0
fi

source "$SCRIPT_DIR/scripts/terminal_classifier.sh"

# Check terminal state using unified classifier
state="$(classify_terminal "$session")"
if [[ "$state" == BUSY:* ]]; then
  echo "NOOP:terminal-busy session=${session} state=$state"
  exit 0
fi
if [[ "$state" == STUCK:* ]]; then
  echo "NOOP:terminal-stuck session=${session} state=$state"
  exit 0
fi

# Run the real dispatch script - it does proper CI/PR/issues checks
output=$("$dispatch_script" 2>&1)
echo "PR-CI: $output"