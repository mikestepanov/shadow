#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"
case "$session" in
  nixelo)
    workdir="$HOME/Desktop/nixelo"
    dispatch_script="$SCRIPT_DIR/scripts/pr_ci_nixelo_dispatch.sh"
    ;;
  starthub)
    workdir="$HOME/Desktop/StartHub"
    dispatch_script="$SCRIPT_DIR/scripts/pr_ci_starthub_dispatch.sh"
    ;;
  *)
    echo "invalid session: $session" >&2
    exit 2
    ;;
esac

source "$SCRIPT_DIR/scripts/terminal_mode_guard.sh"

if ! terminal_send_preflight "$session" "$workdir"; then
  case "$TERMINAL_PREFLIGHT_REASON" in
    session-missing|pane-missing)
      echo "SKIP prci session=${session} reason=${TERMINAL_PREFLIGHT_REASON}"
      ;;
    path-mismatch)
      echo "SKIP prci session=${session} reason=path-mismatch current=$TERMINAL_PREFLIGHT_CURRENT_PATH expected=$workdir"
      ;;
    terminal-not-ready)
      if [[ "$TERMINAL_PREFLIGHT_STATE" == BUSY:* ]]; then
        echo "NOOP:terminal-busy session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      elif [[ "$TERMINAL_PREFLIGHT_STATE" == STUCK:* ]]; then
        echo "NOOP:terminal-stuck session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      else
        echo "BLOCKED_HUMAN: prompt-not-ready-for-prci-ping session=${session} state=$TERMINAL_PREFLIGHT_STATE"
      fi
      ;;
  esac
  exit 0
fi

# Run the real dispatch script - it does proper CI/PR/issues checks
output=$("$dispatch_script" 2>&1)
echo "PR-CI: $output"
