#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
NIX_FALLBACK="nix-shell -p python313Packages.textual --run '~/Desktop/axon/scripts/automationctl'"

if ! command -v python3 >/dev/null 2>&1; then
  echo "automationctl: python3 not found." >&2
  echo "NixOS quick run:" >&2
  echo "  ${NIX_FALLBACK}" >&2
  exit 1
fi

if ! PYTHONPATH="${ROOT_DIR}/tools:${PYTHONPATH:-}" python3 -c 'import textual' >/dev/null 2>&1; then
  echo "automationctl: Python package 'textual' is missing." >&2
  echo "NixOS quick run:" >&2
  echo "  ${NIX_FALLBACK}" >&2
  exit 1
fi

PYTHONPATH="${ROOT_DIR}/tools:${PYTHONPATH:-}" exec python3 -m automationctl.app "$@"
