#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OPENCODECTL="${OPENCODECTL:-${SCRIPT_DIR}/scripts/opencodectl}"
TERMINAL_MODE_GUARD="${TERMINAL_MODE_GUARD:-${SCRIPT_DIR}/scripts/terminal_mode_guard.sh}"

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"
if ! workdir="$($OPENCODECTL lane-field prci "$session" workdir 2>/dev/null)"; then
  echo "invalid session: $session" >&2
  exit 2
fi

if ! dispatch_script="$($OPENCODECTL lane-field prci "$session" dispatchScript 2>/dev/null)"; then
  echo "missing PR-CI dispatch script for session: $session" >&2
  exit 2
fi

source "$TERMINAL_MODE_GUARD"

report_preflight_failure() {
  local note="${1:-}"
  case "$TERMINAL_PREFLIGHT_REASON" in
    session-missing|pane-missing)
      echo "SKIP prci session=${session} reason=${TERMINAL_PREFLIGHT_REASON}${note:+ note=${note}}"
      ;;
    path-mismatch)
      echo "SKIP prci session=${session} reason=path-mismatch current=$TERMINAL_PREFLIGHT_CURRENT_PATH expected=$workdir${note:+ note=${note}}"
      ;;
    terminal-not-ready)
      if [[ "$TERMINAL_PREFLIGHT_STATE" == BUSY:* ]]; then
        echo "NOOP:terminal-busy session=${session} state=$TERMINAL_PREFLIGHT_STATE${note:+ note=${note}}"
      elif [[ "$TERMINAL_PREFLIGHT_STATE" == STUCK:* ]]; then
        echo "NOOP:terminal-stuck session=${session} state=$TERMINAL_PREFLIGHT_STATE${note:+ note=${note}}"
      else
        echo "BLOCKED_HUMAN: prompt-not-ready-for-prci-ping session=${session} state=$TERMINAL_PREFLIGHT_STATE${note:+ note=${note}}"
      fi
      ;;
  esac
}

if ! terminal_send_preflight "$session" "$workdir"; then
  report_preflight_failure
  exit 0
fi

dirty_count="$(repo_dirty_worktree_count "$workdir")"
if [[ "$dirty_count" != "0" ]]; then
  if ! terminal_send_preflight "$session" "$workdir"; then
    report_preflight_failure "final-recheck"
    exit 0
  fi

  target="$TERMINAL_PREFLIGHT_PANE"
  dirty_msg="$(dirty_worktree_recovery_prompt prci "$session" "$workdir" "$dirty_count")"
  send_tmux_text_enter "$target" "$dirty_msg" || {
    echo "BLOCKED_HUMAN: prompt-not-ready-for-prci-dirty-worktree session=${session}"
    exit 0
  }

  echo "PR-CI: SENT dirty-worktree session=${session} changes=${dirty_count}"
  exit 0
fi

# Run the real dispatch script - it does proper CI/PR/issues checks
output=$("$dispatch_script" 2>&1)
echo "PR-CI: $output"
