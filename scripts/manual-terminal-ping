#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OPENCODECTL="${OPENCODECTL:-${SCRIPT_DIR}/scripts/opencodectl}"
TERMINAL_MODE_GUARD="${TERMINAL_MODE_GUARD:-${SCRIPT_DIR}/scripts/terminal_mode_guard.sh}"
MANUAL_PING_STATE_DIR="${MANUAL_PING_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/shadow/manual-terminal-ping}"
MANUAL_PING_REPEAT_COOLDOWN_SECONDS="${MANUAL_PING_REPEAT_COOLDOWN_SECONDS:-1800}"

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <nixelo|starthub>" >&2
  exit 2
fi

session="$1"
if ! workdir="$($OPENCODECTL lane-field manual "$session" workdir 2>/dev/null)"; then
  echo "invalid session: $session" >&2
  exit 2
fi

if ! msg="$($OPENCODECTL lane-field manual "$session" prompt 2>/dev/null)"; then
  echo "missing manual prompt for session: $session" >&2
  exit 2
fi

if ! tmux has-session -t "$session" 2>/dev/null; then
  echo "SKIP manual session=${session} reason=session-missing"
  exit 0
fi

source "$TERMINAL_MODE_GUARD"

report_preflight_failure() {
  local note="${1:-}"
  case "$TERMINAL_PREFLIGHT_REASON" in
    session-missing|pane-missing)
      echo "SKIP manual session=${session} reason=${TERMINAL_PREFLIGHT_REASON}${note:+ note=${note}}"
      ;;
    path-mismatch)
      echo "SKIP manual session=${session} reason=path-mismatch current=$TERMINAL_PREFLIGHT_CURRENT_PATH expected=$workdir${note:+ note=${note}}"
      ;;
    terminal-not-ready)
      if [[ "$TERMINAL_PREFLIGHT_STATE" == BUSY:* ]]; then
        echo "NOOP:terminal-busy session=${session} state=$TERMINAL_PREFLIGHT_STATE${note:+ note=${note}}"
      elif [[ "$TERMINAL_PREFLIGHT_STATE" == STUCK:* ]]; then
        echo "NOOP:terminal-stuck session=${session} state=$TERMINAL_PREFLIGHT_STATE${note:+ note=${note}}"
      else
        echo "BLOCKED_HUMAN: prompt-not-ready-for-manual-ping session=${session} state=$TERMINAL_PREFLIGHT_STATE${note:+ note=${note}}"
      fi
      ;;
  esac
}

message_fingerprint() {
  printf '%s' "$1" | cksum | cut -d' ' -f1
}

manual_ping_state_file() {
  printf '%s/%s.last' "$MANUAL_PING_STATE_DIR" "$1"
}

manual_repeat_suppressed() {
  local session_name="$1"
  local text="$2"
  local state_file current_fingerprint now last_timestamp last_fingerprint age

  state_file="$(manual_ping_state_file "$session_name")"
  current_fingerprint="$(message_fingerprint "$text")"
  now="$(date +%s)"

  if [[ ! -f "$state_file" ]]; then
    return 1
  fi

  read -r last_timestamp last_fingerprint < "$state_file" || return 1
  if [[ -z "${last_timestamp:-}" || -z "${last_fingerprint:-}" || "$last_fingerprint" != "$current_fingerprint" ]]; then
    return 1
  fi

  age=$((now - last_timestamp))
  if (( age < 0 || age >= MANUAL_PING_REPEAT_COOLDOWN_SECONDS )); then
    return 1
  fi

  printf 'NOOP:repeat-suppressed session=%s age=%ss cooldown=%ss\n' "$session_name" "$age" "$MANUAL_PING_REPEAT_COOLDOWN_SECONDS"
  return 0
}

record_manual_send() {
  local session_name="$1"
  local text="$2"
  local state_file

  mkdir -p "$MANUAL_PING_STATE_DIR"
  state_file="$(manual_ping_state_file "$session_name")"
  printf '%s %s\n' "$(date +%s)" "$(message_fingerprint "$text")" > "$state_file"
}

if ! terminal_send_preflight "$session" "$workdir"; then
  report_preflight_failure
  exit 0
fi

target="$TERMINAL_PREFLIGHT_PANE"

has_error_loop() {
  local text="$1"
  printf '%s\n' "$text" | grep -Eiq '(-bash: .*command not found|syntax error near unexpected token|parse error|Traceback)'
}

# We're using OpenCode now, no need to check/ensure CLI
# Just verify we're on OpenCode and send the prompt

mode="opencode"

pane_tail="$(tmux capture-pane -t "$target" -p | tail -30)"
if has_error_loop "$pane_tail"; then
  echo "SKIP manual session=${session} reason=error-loop-detected"
  exit 0
fi

dirty_count="$(repo_dirty_worktree_count "$workdir")"
if [[ "$dirty_count" != "0" ]]; then
  if ! terminal_send_preflight "$session" "$workdir"; then
    report_preflight_failure "final-recheck"
    exit 0
  fi

  target="$TERMINAL_PREFLIGHT_PANE"
  dirty_msg="$(dirty_worktree_recovery_prompt manual "$session" "$workdir" "$dirty_count")"
  if manual_repeat_suppressed "$session" "$dirty_msg"; then
    exit 0
  fi

  send_tmux_text_enter "$target" "$dirty_msg" || {
    echo "BLOCKED_HUMAN: prompt-not-ready-for-manual-dirty-worktree session=${session}"
    exit 0
  }

  record_manual_send "$session" "$dirty_msg"

  echo "SENT manual session=${session} mode=dirty-worktree changes=${dirty_count}"
  exit 0
fi

if ! terminal_send_preflight "$session" "$workdir"; then
  report_preflight_failure "final-recheck"
  exit 0
fi

target="$TERMINAL_PREFLIGHT_PANE"

if manual_repeat_suppressed "$session" "$msg"; then
  exit 0
fi

send_tmux_text_enter "$target" "$msg" || {
  echo "BLOCKED_HUMAN: prompt-not-ready-for-manual-ping session=${session}"
  exit 0
}

record_manual_send "$session" "$msg"

echo "SENT manual session=${session} msg=${msg:0:50}..."
