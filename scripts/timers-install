#!/run/current-system/sw/bin/bash
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
REPO_SYSTEMD_DIR="$REPO_DIR/systemd"
USER_SYSTEMD_DIR="$HOME/.config/systemd/user"

usage() {
  echo "Usage: $0 <timer-name|all>"
  echo "Examples:"
  echo "  $0 sync-repos"
  echo "  $0 manual-terminal-nixelo"
  echo "  $0 all"
}

if [ "${1:-}" = "" ]; then
  usage
  exit 1
fi

target="$1"
mkdir -p "$USER_SYSTEMD_DIR"

mapfile -t ALL_TIMERS < <(find "$REPO_SYSTEMD_DIR" -maxdepth 1 -type f -name '*.timer' -printf '%f\n' | sort)

resolve_units() {
  if [ "$target" = "all" ]; then
    printf '%s\n' "${ALL_TIMERS[@]}"
    return
  fi

  local unit="$target"
  [[ "$unit" == *.timer ]] || unit+=".timer"
  if [ ! -f "$REPO_SYSTEMD_DIR/$unit" ]; then
    echo "Timer not found in repo: $unit" >&2
    exit 2
  fi
  printf '%s\n' "$unit"
}

mapfile -t UNITS < <(resolve_units)

for unit in "${UNITS[@]}"; do
  service="${unit%.timer}.service"

  rm -f "$USER_SYSTEMD_DIR/$unit" "$USER_SYSTEMD_DIR/$service"
  ln -s "$REPO_SYSTEMD_DIR/$unit" "$USER_SYSTEMD_DIR/$unit"
  if [ -f "$REPO_SYSTEMD_DIR/$service" ]; then
    ln -s "$REPO_SYSTEMD_DIR/$service" "$USER_SYSTEMD_DIR/$service"
  fi

done

systemctl --user daemon-reload

for unit in "${UNITS[@]}"; do
  systemctl --user unmask "$unit" || true
  systemctl --user enable --now "$unit"
done

for unit in "${UNITS[@]}"; do
  echo "--- $unit ---"
  systemctl --user is-active "$unit" || true
  systemctl --user is-enabled "$unit" || true
done
