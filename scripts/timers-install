#!/run/current-system/sw/bin/bash
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
REPO_SYSTEMD_DIR="$REPO_DIR/systemd"
USER_SYSTEMD_DIR="$HOME/.local/share/systemd/user"
INSTALL_ONLY="no"

render_service_from_template() {
  local service_name="$1"
  local user_service_path="$2"
  local mode repo template_name template_path

  case "$service_name" in
    manual-terminal-*.service)
      mode="manual-terminal"
      repo="${service_name#manual-terminal-}"
      repo="${repo%.service}"
      ;;
    prci-terminal-*.service)
      mode="prci-terminal"
      repo="${service_name#prci-terminal-}"
      repo="${repo%.service}"
      ;;
    agent-terminal-*.service)
      mode="agent-terminal"
      repo="${service_name#agent-terminal-}"
      repo="${repo%.service}"
      ;;
    *)
      return 1
      ;;
  esac

  template_name="${mode}@.service.template"
  template_path="$REPO_SYSTEMD_DIR/$template_name"
  [ -f "$template_path" ] || return 1

  sed "s/%i/${repo}/g" "$template_path" > "$user_service_path"
}

usage() {
  echo "Usage: $0 [--install-only] <timer-name|all>"
  echo "Examples:"
  echo "  $0 sync-repos"
  echo "  $0 manual-terminal-nixelo"
  echo "  $0 all"
}

if [ "${1:-}" = "--install-only" ]; then
  INSTALL_ONLY="yes"
  shift
fi

if [ "${1:-}" = "" ]; then
  usage
  exit 1
fi

target="$1"
mkdir -p "$USER_SYSTEMD_DIR"

mapfile -t ALL_TIMERS < <(find "$REPO_SYSTEMD_DIR" -maxdepth 1 -type f -name '*.timer' -printf '%f\n' | sort)

resolve_units() {
  if [ "$target" = "all" ]; then
    printf '%s\n' "${ALL_TIMERS[@]}"
    return
  fi

  local unit="$target"
  [[ "$unit" == *.timer ]] || unit+=".timer"
  if [ ! -f "$REPO_SYSTEMD_DIR/$unit" ]; then
    echo "Timer not found in repo: $unit" >&2
    exit 2
  fi
  printf '%s\n' "$unit"
}

mapfile -t UNITS < <(resolve_units)

for unit in "${UNITS[@]}"; do
  service="${unit%.timer}.service"

  cp -f "$REPO_SYSTEMD_DIR/$unit" "$USER_SYSTEMD_DIR/$unit"
  if [ -f "$REPO_SYSTEMD_DIR/$service" ]; then
    if ! render_service_from_template "$service" "$USER_SYSTEMD_DIR/$service"; then
      cp -f "$REPO_SYSTEMD_DIR/$service" "$USER_SYSTEMD_DIR/$service"
    fi
  fi

done

systemctl --user daemon-reload

if [ "$INSTALL_ONLY" = "yes" ]; then
  for unit in "${UNITS[@]}"; do
    echo "--- $unit ---"
    systemctl --user show "$unit" --property=LoadState,UnitFileState,FragmentPath || true
  done
  exit 0
fi

for unit in "${UNITS[@]}"; do
  systemctl --user unmask "$unit" || true
  systemctl --user enable --now "$unit"
done

for unit in "${UNITS[@]}"; do
  echo "--- $unit ---"
  systemctl --user is-active "$unit" || true
  systemctl --user is-enabled "$unit" || true
done
