#!/usr/bin/env bash
# YO — DO NOT MODIFY THIS FILE UNLESS EXPLICITLY REQUESTED BY THE USER.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
OPENCODECTL="${OPENCODECTL:-$SCRIPT_DIR/opencodectl}"
TIMERS_INSTALL="${TIMERS_INSTALL:-$SCRIPT_DIR/timers-install}"
TERMINAL_MODE_GUARD="${TERMINAL_MODE_GUARD:-$SCRIPT_DIR/terminal_mode_guard.sh}"

source "$TERMINAL_MODE_GUARD"

# Terminal Automation guardrail utility
# Enforces terminal automation checks across:
# 1) canonical systemd user timers (manual-*/agent-*/prci-terminal-*)
# 2) legacy OpenCode PR-CI cron jobs kept disabled to avoid split-brain

SYSTEMD_UNITS=(
  manual-terminal-nixelo.timer
  manual-terminal-starthub.timer
  agent-terminal-nixelo.timer
  agent-terminal-starthub.timer
  prci-terminal-nixelo.timer
  prci-terminal-starthub.timer
)

LEGACY_PRCI_CRONS=(
  pr-ci-nixelo
  pr-ci-starthub
)

declare -A TERMINAL_SESSION=(
  [manual-terminal-nixelo.timer]="nixelo"
  [manual-terminal-starthub.timer]="starthub"
  [agent-terminal-nixelo.timer]="nixelo"
  [agent-terminal-starthub.timer]="starthub"
  [prci-terminal-nixelo.timer]="nixelo"
  [prci-terminal-starthub.timer]="starthub"
)

declare -A TERMINAL_WORKDIR=(
  [manual-terminal-nixelo.timer]="$HOME/Desktop/nixelo"
  [manual-terminal-starthub.timer]="$HOME/Desktop/StartHub"
  [agent-terminal-nixelo.timer]="$HOME/Desktop/nixelo"
  [agent-terminal-starthub.timer]="$HOME/Desktop/StartHub"
  [prci-terminal-nixelo.timer]="$HOME/Desktop/nixelo"
  [prci-terminal-starthub.timer]="$HOME/Desktop/StartHub"
)

declare -A TERMINAL_VERIFY_RE=(
  [manual-terminal-nixelo.timer]='SENT manual session=nixelo'
  [manual-terminal-starthub.timer]='SENT manual session=starthub'
  [agent-terminal-nixelo.timer]='SENT role=.* session=nixelo'
  [agent-terminal-starthub.timer]='SENT role=.* session=starthub'
  [prci-terminal-nixelo.timer]='PR-CI:'
  [prci-terminal-starthub.timer]='PR-CI:'
)

PLAN_DIR="${HOME}/.openclaw/workspace/.terminal-automation-plans"
mkdir -p "$PLAN_DIR"

usage() {
  cat <<'EOF'
Usage:
  scripts/terminal-automation status
  scripts/terminal-automation plan <action> <scope>    Plan a state change (prints plan, does NOT execute)
  scripts/terminal-automation execute <plan-id>        Execute a previously planned change
  scripts/terminal-automation off [all|nixelo|starthub] [--clean-failed]   (LEGACY — prefer plan/execute)
  scripts/terminal-automation assert-off [all|nixelo|starthub]

Actions for plan:
  enable-manual <nixelo|starthub|all>
  disable-manual <nixelo|starthub|all>
  enable-agent <nixelo|starthub|all>
  disable-agent <nixelo|starthub|all>
  enable-prci <nixelo|starthub|all>
  disable-prci <nixelo|starthub|all>
  off <all|nixelo|starthub>

Notes:
  - "OFF" means both control planes are off.
  - For canonical systemd timer units: keep unit files installed; OFF is inactive + masked.
  - Legacy OpenClaw PR-CI jobs should stay disabled unless a migration explicitly needs them.
  - AI agents MUST use plan/execute flow. Direct openclaw cron/systemctl calls are forbidden.
EOF
}

scope_units() {
  local scope="$1" filter="${2:-all}"
  local units=()
  case "$scope" in
    all)
      case "$filter" in
        manual) units=(manual-terminal-nixelo.timer manual-terminal-starthub.timer) ;;
        agent)  units=(agent-terminal-nixelo.timer agent-terminal-starthub.timer) ;;
        prci)   units=(prci-terminal-nixelo.timer prci-terminal-starthub.timer) ;;
        *)      units=("${SYSTEMD_UNITS[@]}") ;;
      esac
      ;;
    nixelo)
      case "$filter" in
        manual) units=(manual-terminal-nixelo.timer) ;;
        agent)  units=(agent-terminal-nixelo.timer) ;;
        prci)   units=(prci-terminal-nixelo.timer) ;;
        *)      units=(manual-terminal-nixelo.timer agent-terminal-nixelo.timer prci-terminal-nixelo.timer) ;;
      esac
      ;;
    starthub)
      case "$filter" in
        manual) units=(manual-terminal-starthub.timer) ;;
        agent)  units=(agent-terminal-starthub.timer) ;;
        prci)   units=(prci-terminal-starthub.timer) ;;
        *)      units=(manual-terminal-starthub.timer agent-terminal-starthub.timer prci-terminal-starthub.timer) ;;
      esac
      ;;
    *)
      echo "invalid scope: $scope" >&2
      exit 2
      ;;
  esac
  printf '%s\n' "${units[@]}"
}

scope_legacy_prci_crons() {
  local scope="$1"
  case "$scope" in
    all)
      printf '%s\n' "${LEGACY_PRCI_CRONS[@]}"
      ;;
    nixelo)
      printf '%s\n' pr-ci-nixelo
      ;;
    starthub)
      printf '%s\n' pr-ci-starthub
      ;;
    *)
      echo "invalid scope: $scope" >&2
      exit 2
      ;;
  esac
}

unit_active() { systemctl --user is-active "$1" 2>&1 || true; }
unit_enabled() { systemctl --user is-enabled "$1" 2>&1 || true; }

declare -A ROLLBACK_ACTIVE_STATE=()
declare -A ROLLBACK_ENABLED_STATE=()

ensure_timer_installed() {
  local unit="$1"
  "$TIMERS_INSTALL" --install-only "${unit%.timer}" >/dev/null
}

terminal_timer_session() {
  printf '%s' "${TERMINAL_SESSION[$1]:-}"
}

terminal_timer_workdir() {
  printf '%s' "${TERMINAL_WORKDIR[$1]:-}"
}

terminal_timer_verify_re() {
  printf '%s' "${TERMINAL_VERIFY_RE[$1]:-}"
}

capture_rollback_state() {
  local unit="$1"
  ROLLBACK_ACTIVE_STATE["$unit"]="$(unit_active "$unit")"
  ROLLBACK_ENABLED_STATE["$unit"]="$(unit_enabled "$unit")"
}

restore_unit_state() {
  local unit="$1"
  local prev_active prev_enabled

  prev_active="${ROLLBACK_ACTIVE_STATE[$unit]:-inactive}"
  prev_enabled="${ROLLBACK_ENABLED_STATE[$unit]:-disabled}"

  case "$prev_enabled" in
    masked)
      systemctl --user mask "$unit" >/dev/null 2>&1 || true
      ;;
    enabled)
      systemctl --user unmask "$unit" >/dev/null 2>&1 || true
      systemctl --user enable "$unit" >/dev/null 2>&1 || true
      ;;
    *)
      systemctl --user unmask "$unit" >/dev/null 2>&1 || true
      systemctl --user disable "$unit" >/dev/null 2>&1 || true
      ;;
  esac

  case "$prev_active" in
    active|activating|reloading)
      systemctl --user start "$unit" >/dev/null 2>&1 || true
      ;;
    *)
      systemctl --user stop "$unit" >/dev/null 2>&1 || true
      ;;
  esac
}

timer_preflight() {
  local unit="$1"
  local session workdir

  session="$(terminal_timer_session "$unit")"
  workdir="$(terminal_timer_workdir "$unit")"
  [[ -n "$session" && -n "$workdir" ]] || return 0

  if ! terminal_send_preflight "$session" "$workdir"; then
    case "$TERMINAL_PREFLIGHT_REASON" in
      session-missing|pane-missing)
        echo "PREFLIGHT_FAIL $unit reason=$TERMINAL_PREFLIGHT_REASON session=$session" >&2
        return 1
        ;;
      path-mismatch)
        echo "PREFLIGHT_FAIL $unit reason=path-mismatch session=$session current=$TERMINAL_PREFLIGHT_CURRENT_PATH expected=$workdir" >&2
        return 1
        ;;
      terminal-not-ready)
        echo "PREFLIGHT_BYPASS $unit session=$session state=$TERMINAL_PREFLIGHT_STATE" >&2
        return 0
        ;;
    esac
  fi

  echo "PREFLIGHT_OK $unit session=$session state=$TERMINAL_PREFLIGHT_STATE"
}

verify_timer_dispatch() {
  local unit="$1"
  local verify_re service since logs outcome

  verify_re="$(terminal_timer_verify_re "$unit")"
  [[ -n "$verify_re" ]] || return 0

  service="${unit%.timer}.service"
  since="$(date '+%Y-%m-%d %H:%M:%S')"

  if ! systemctl --user start "$service" >/dev/null 2>&1; then
    echo "VERIFY_FAIL $unit reason=service-start-failed service=$service" >&2
    return 1
  fi

  sleep 2
  logs="$(journalctl --user -u "$service" --since "$since" --no-pager 2>/dev/null || true)"

  if printf '%s\n' "$logs" | grep -Eq "$verify_re"; then
    echo "VERIFY_OK $unit dispatch=verified"
    return 0
  fi

  outcome="$(printf '%s\n' "$logs" | grep -E 'SENT |PR-CI:|NOOP:|SKIP |BLOCKED_HUMAN:|OK:' | tail -1 || true)"
  if [[ -z "$outcome" ]]; then
    outcome="no-dispatch-log"
  fi

  if [[ "$outcome" == *NOOP:terminal-busy* ]]; then
    echo "VERIFY_OK $unit dispatch=$outcome"
    return 0
  fi

  echo "VERIFY_FAIL $unit dispatch=$outcome" >&2
  return 1
}

rollback_units() {
  local unit
  for unit in "$@"; do
    [[ -n "$unit" ]] || continue
    restore_unit_state "$unit"
  done
}

enable_terminal_units() {
  local scope="$1"
  local filter="$2"
  local enabled_units=()
  local unit

  while IFS= read -r unit; do
    ensure_timer_installed "$unit"
    capture_rollback_state "$unit"
    if ! timer_preflight "$unit"; then
      rollback_units "${enabled_units[@]}" "$unit"
      return 1
    fi
    systemctl --user unmask "$unit" >/dev/null 2>&1 || true
    systemctl --user enable "$unit" >/dev/null 2>&1 || true
    systemctl --user start "$unit" >/dev/null 2>&1 || true
    enabled_units+=("$unit")
    if ! verify_timer_dispatch "$unit"; then
      rollback_units "${enabled_units[@]}"
      return 1
    fi
  done < <(scope_units "$scope" "$filter")
}

disable_terminal_units() {
  local scope="$1"
  local filter="$2"
  local unit

  while IFS= read -r unit; do
    ensure_timer_installed "$unit"
    systemctl --user stop "$unit" >/dev/null 2>&1 || true
    systemctl --user mask "$unit" >/dev/null 2>&1 || true
  done < <(scope_units "$scope" "$filter")
}

cron_list_json() { "$OPENCODECTL" cron list --all --json; }
cron_job_id_by_name() {
  local name="$1"
  cron_list_json | node -e 'const fs=require("fs"); const n=process.argv[1]; const data=JSON.parse(fs.readFileSync(0,"utf8")); const jobs=Array.isArray(data)?data:(data.jobs||[]); const row=jobs.find((j)=>j.name===n); if(row) process.stdout.write(row.id);' "$name"
}
cron_job_status_by_name() {
  local name="$1"
  cron_list_json | node -e 'const fs=require("fs"); const n=process.argv[1]; const data=JSON.parse(fs.readFileSync(0,"utf8")); const jobs=Array.isArray(data)?data:(data.jobs||[]); const row=jobs.find((j)=>j.name===n); if(row){ process.stdout.write(row.enabled? (row.state?.lastStatus || "enabled") : "disabled"); }' "$name"
}

print_status() {
  echo "== Terminal Automation Timers =="
  while IFS= read -r unit; do
    local a e
    a="$(unit_active "$unit")"
    e="$(unit_enabled "$unit")"
    printf '%-34s active=%-10s enabled=%-10s\n' "$unit" "$a" "$e"
  done < <(scope_units all)

  echo
  echo "== Legacy OpenCode PR-CI Jobs =="
  while IFS= read -r name; do
    local id st
    id="$(cron_job_id_by_name "$name")"
    st="$(cron_job_status_by_name "$name")"
    if [[ -z "$id" ]]; then
      printf '%-18s id=%-36s status=%s\n' "$name" "(missing)" "missing"
    else
      printf '%-18s id=%-36s status=%s\n' "$name" "$id" "$st"
    fi
  done < <(scope_legacy_prci_crons all)

  echo
  echo "== Failed user units =="
  systemctl --user --failed --no-legend || true
}

systemd_off_ok() {
  local unit="$1"
  local a e
  a="$(unit_active "$unit")"
  e="$(unit_enabled "$unit")"

  local active_ok=0 enabled_ok=0
  [[ "$a" == "inactive" || "$a" == "failed" || "$a" == "unknown" ]] && active_ok=1
  [[ "$e" == "masked" ]] && enabled_ok=1

  [[ $active_ok -eq 1 && $enabled_ok -eq 1 ]]
}

cron_off_ok() {
  local name="$1"
  local st
  st="$(cron_job_status_by_name "$name")"
  [[ "$st" == "disabled" || -z "$st" ]]
}

set_legacy_prci_crons_enabled() {
  local scope="$1"
  local enabled="$2"
  local name id

  while IFS= read -r name; do
    id="$(cron_job_id_by_name "$name")"
    [[ -n "$id" ]] || continue
    if [[ "$enabled" == "true" ]]; then
      "$OPENCODECTL" cron enable "$id" >/dev/null
    else
      "$OPENCODECTL" cron disable "$id" >/dev/null
    fi
  done < <(scope_legacy_prci_crons "$scope")
}

set_off() {
  local scope="$1"
  local clean_failed="$2"

  echo "[off] scope=$scope"

  # systemd plane
  while IFS= read -r unit; do
    ensure_timer_installed "$unit"
    systemctl --user stop "$unit" 2>/dev/null || true
    systemctl --user mask "$unit" 2>/dev/null || true
  done < <(scope_units "$scope")

  # Legacy OpenCode PR-CI plane
  set_legacy_prci_crons_enabled "$scope" "false"

  if [[ "$clean_failed" == "yes" ]]; then
    systemctl --user reset-failed || true
  fi
}

assert_off() {
  local scope="$1"
  local ok=1

  while IFS= read -r unit; do
    if ! systemd_off_ok "$unit"; then
      echo "ASSERT_FAIL systemd $unit active=$(unit_active "$unit") enabled=$(unit_enabled "$unit")"
      ok=0
    fi
  done < <(scope_units "$scope")

  while IFS= read -r name; do
    if ! cron_off_ok "$name"; then
      echo "ASSERT_FAIL cron $name status=$(cron_job_status_by_name "$name")"
      ok=0
    fi
  done < <(scope_legacy_prci_crons "$scope")

  if [[ "$ok" -eq 1 ]]; then
    echo "ASSERT_OK off scope=$scope"
  else
    return 1
  fi
}

create_plan() {
  local action="$1"
  local scope="$2"
  local plan_id
  plan_id="$(date +%s)-$$"
  local plan_file="$PLAN_DIR/$plan_id.json"
  local changes=""

  case "$action" in
    enable-manual)
      changes="Enable manual-terminal timers"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → active=active enabled=enabled"
      done < <(scope_units "$scope" "manual")
      ;;
    disable-manual)
      changes="Disable manual-terminal timers"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → active=inactive enabled=masked"
      done < <(scope_units "$scope" "manual")
      ;;
    enable-agent)
      changes="Enable agent-terminal timers"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → active=active enabled=enabled"
      done < <(scope_units "$scope" "agent")
      ;;
    disable-agent)
      changes="Disable agent-terminal timers"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → active=inactive enabled=masked"
      done < <(scope_units "$scope" "agent")
      ;;
    enable-prci)
      changes="Enable PR-CI terminal timers"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → active=active enabled=enabled"
      done < <(scope_units "$scope" "prci")
      while IFS= read -r name; do
        local st
        st="$(cron_job_status_by_name "$name")"
        changes="$changes\n  $name: status=$st → status=disabled (legacy split-brain guard)"
      done < <(scope_legacy_prci_crons "$scope")
      ;;
    disable-prci)
      changes="Disable PR-CI terminal timers"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → active=inactive enabled=masked"
      done < <(scope_units "$scope" "prci")
      while IFS= read -r name; do
        local st
        st="$(cron_job_status_by_name "$name")"
        changes="$changes\n  $name: status=$st → status=disabled"
      done < <(scope_legacy_prci_crons "$scope")
      ;;
    off)
      changes="Turn OFF all terminal automation"
      while IFS= read -r unit; do
        local a e
        a="$(unit_active "$unit")"
        e="$(unit_enabled "$unit")"
        changes="$changes\n  $unit: active=$a enabled=$e → OFF"
      done < <(scope_units "$scope")
      while IFS= read -r name; do
        local st
        st="$(cron_job_status_by_name "$name")"
        changes="$changes\n  $name: status=$st → disabled"
      done < <(scope_legacy_prci_crons "$scope")
      ;;
    *)
      echo "Unknown action: $action" >&2
      return 2
      ;;
  esac

  # Write plan file
  cat > "$plan_file" <<EOF
{"plan_id":"$plan_id","action":"$action","scope":"$scope","created_at":$(date +%s),"executed":false}
EOF

  echo "═══════════════════════════════════════════"
  echo "  PLAN $plan_id"
  echo "═══════════════════════════════════════════"
  printf '%b\n' "$changes"
  echo ""
  echo "To execute: scripts/terminal-automation execute $plan_id"
  echo "═══════════════════════════════════════════"
}

execute_plan() {
  local plan_id="$1"
  local plan_file="$PLAN_DIR/$plan_id.json"

  if [[ ! -f "$plan_file" ]]; then
    echo "ERROR: No plan found with id '$plan_id'. Run 'plan' first." >&2
    return 1
  fi

  # Check if already executed
  if grep -q '"executed":true' "$plan_file"; then
    echo "ERROR: Plan '$plan_id' was already executed." >&2
    return 1
  fi

  # Parse plan
  local action scope
  action=$(node -e "const d=JSON.parse(require('fs').readFileSync('$plan_file','utf8')); process.stdout.write(d.action)")
  scope=$(node -e "const d=JSON.parse(require('fs').readFileSync('$plan_file','utf8')); process.stdout.write(d.scope)")

  echo "Executing plan $plan_id: action=$action scope=$scope"

  case "$action" in
    enable-manual)
      enable_terminal_units "$scope" "manual"
      ;;
    disable-manual)
      disable_terminal_units "$scope" "manual"
      ;;
    enable-agent)
      enable_terminal_units "$scope" "agent"
      ;;
    disable-agent)
      disable_terminal_units "$scope" "agent"
      ;;
    enable-prci)
      enable_terminal_units "$scope" "prci"
      set_legacy_prci_crons_enabled "$scope" "false"
      ;;
    disable-prci)
      disable_terminal_units "$scope" "prci"
      set_legacy_prci_crons_enabled "$scope" "false"
      ;;
    off)
      set_off "$scope" "no"
      ;;
    *)
      echo "ERROR: Unknown action '$action'" >&2
      return 1
      ;;
  esac

  # Mark as executed
  sed -i 's/"executed":false/"executed":true/' "$plan_file"

  echo ""
  echo "=== Post-execution state ==="
  print_status
}

# Clean up old plans (>24h)
find "$PLAN_DIR" -name '*.json' -mmin +1440 -delete 2>/dev/null || true

main() {
  local cmd="${1:-}"
  case "$cmd" in
    status)
      print_status
      ;;
    plan)
      local action="${2:-}"
      local scope="${3:-all}"
      if [[ -z "$action" ]]; then
        echo "Usage: terminal-automation plan <action> <scope>" >&2
        exit 2
      fi
      create_plan "$action" "$scope"
      ;;
    execute)
      local plan_id="${2:-}"
      if [[ -z "$plan_id" ]]; then
        echo "Usage: terminal-automation execute <plan-id>" >&2
        exit 2
      fi
      execute_plan "$plan_id"
      ;;
    off)
      local scope="${2:-all}"
      local clean_failed="no"
      if [[ "${3:-}" == "--clean-failed" || "${2:-}" == "--clean-failed" ]]; then
        clean_failed="yes"
      fi
      set_off "$scope" "$clean_failed"
      print_status
      assert_off "$scope"
      ;;
    assert-off)
      local scope="${2:-all}"
      assert_off "$scope"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      usage
      exit 2
      ;;
  esac
}

main "$@"
